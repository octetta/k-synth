/* ═══════════════════════════════════════════════════════════════════
   WAV EXPORT
   ═══════════════════════════════════════════════════════════════════ */

function downloadWav(f32, filename) {
  // build a minimal 16-bit PCM WAV in memory
  const numSamples = f32.length;
  const numChannels = 1;
  const bitsPerSample = 16;
  const byteRate = SR * numChannels * bitsPerSample / 8;
  const blockAlign = numChannels * bitsPerSample / 8;
  const dataSize = numSamples * blockAlign;
  const buffer = new ArrayBuffer(44 + dataSize);
  const view = new DataView(buffer);

  function writeStr(off, s) {
    for (let i = 0; i < s.length; i++) view.setUint8(off + i, s.charCodeAt(i));
  }
  writeStr(0,  'RIFF');
  view.setUint32(4,  36 + dataSize, true);
  writeStr(8,  'WAVE');
  writeStr(12, 'fmt ');
  view.setUint32(16, 16, true);           // PCM chunk size
  view.setUint16(20, 1,  true);           // PCM format
  view.setUint16(22, numChannels, true);
  view.setUint32(24, SR, true);
  view.setUint32(28, byteRate, true);
  view.setUint16(32, blockAlign, true);
  view.setUint16(34, bitsPerSample, true);
  writeStr(36, 'data');
  view.setUint32(40, dataSize, true);

  // convert float32 → int16
  let off = 44;
  for (let i = 0; i < numSamples; i++) {
    const s = Math.max(-1, Math.min(1, f32[i]));
    view.setInt16(off, s < 0 ? s * 0x8000 : s * 0x7FFF, true);
    off += 2;
  }

  const blob = new Blob([buffer], { type: 'audio/wav' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href     = url;
  a.download = filename;
  a.click();
  URL.revokeObjectURL(url);
}

/* ═══════════════════════════════════════════════════════════════════
   SAVE / LOAD
   ═══════════════════════════════════════════════════════════════════ */

(function () {
  const MAGIC   = 'ksynth-session-v1';

  // Float32Array → base64 string
  function f32ToB64(f32) {
    const bytes = new Uint8Array(f32.buffer);
    let bin = '';
    for (let i = 0; i < bytes.length; i++) bin += String.fromCharCode(bytes[i]);
    return btoa(bin);
  }

  // base64 string → Float32Array
  function b64ToF32(b64) {
    const bin   = atob(b64);
    const bytes = new Uint8Array(bin.length);
    for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
    return new Float32Array(bytes.buffer);
  }

  function saveSession() {
    const session = {
      magic: MAGIC,
      saved: new Date().toISOString(),
      slots: slots.map(s => ({
        label:    s.label,
        baseRate: s.baseRate,
        audio:    s._f32 ? f32ToB64(s._f32) : null,
      })),
      pads: pads.map(p => ({ slot: p.slot, semitones: p.semitones })),
      // save full history entries including audio so notebook rebuilds completely
      history: history.slice().reverse().map(h => ({
        code:     h.code,
        success:  h.success,
        samples:  h.samples,
        error:    h.error,
        audio:    h.floatData ? f32ToB64(h.floatData) : null,
      })),
    };

    const json = JSON.stringify(session);
    const blob = new Blob([json], { type: 'application/json' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    const ts   = new Date().toISOString().slice(0,19).replace(/[T:]/g, '-');
    a.href     = url;
    a.download = `ksynth-${ts}.json`;
    a.click();
    URL.revokeObjectURL(url);
  }

  async function loadSession(file) {
    let session;
    try {
      session = JSON.parse(await file.text());
    } catch(e) {
      alert('Could not parse file: ' + e.message);
      return;
    }
    if (session.magic !== MAGIC) {
      alert('Not a ksynth session file.');
      return;
    }

    ensureAudio();

    // restore slots
    session.slots.forEach((sd, i) => {
      slots[i].label    = sd.label;
      slots[i].baseRate = sd.baseRate ?? 1.0;
      if (sd.audio) {
        const f32 = b64ToF32(sd.audio);
        slots[i]._f32   = f32;
        slots[i].buffer = floatArrayToAudioBuffer(f32);
      } else {
        slots[i]._f32   = null;
        slots[i].buffer = null;
      }
    });

    // restore pads
    session.pads.forEach((pd, i) => {
      pads[i].slot      = pd.slot;
      pads[i].semitones = pd.semitones;
    });

    // restore history and rebuild notebook
    history.length = 0;
    document.getElementById('notebook').innerHTML = '';
    histIdx = -1;

    (session.history || []).forEach(hd => {
      const f32   = hd.audio ? b64ToF32(hd.audio) : null;
      const entry = {
        code:      hd.code,
        success:   hd.success,
        samples:   hd.samples,
        error:     hd.error,
        floatData: f32,
      };
      history.unshift(entry);   // unshift keeps most-recent at index 0
      addNotebookCell(entry);
    });

    renderSlotStrip();
    renderPadGrid();
  }

  document.getElementById('btn-save').addEventListener('click', saveSession);

  document.getElementById('btn-load').addEventListener('click', () => {
    document.getElementById('load-input').click();
  });

  document.getElementById('load-input').addEventListener('change', e => {
    const file = e.target.files[0];
    if (file) loadSession(file);
    e.target.value = ''; // reset so same file can be reloaded
  });
}());

/* ═══════════════════════════════════════════════════════════════════
   PATCH BROWSER
   ═══════════════════════════════════════════════════════════════════ */

(function () {
  const REPO    = 'octetta/k-synth';
  const API     = `https://api.github.com/repos/${REPO}`;
  const RAW     = `https://raw.githubusercontent.com/${REPO}/HEAD`;

  const browser  = document.getElementById('patch-browser');
  const list     = document.getElementById('patch-list');
  const status   = document.getElementById('patch-status');
  const search   = document.getElementById('patch-search');
  const btnOpen  = document.getElementById('btn-patches');
  const btnClose = document.getElementById('btn-patch-close');
  const btnFix   = document.getElementById('btn-fix');

  let allPatches = []; // [{path, name, dir}]
  let loaded     = false;

  function open() {
    browser.classList.add('open');
    search.value = '';
    search.focus();
    if (!loaded) fetchPatches();
    else render('');
  }

  function close() {
    browser.classList.remove('open');
    editor.focus();
  }

  async function fetchPatches() {
    status.textContent = 'fetching patch list…';
    list.innerHTML = '';
    list.appendChild(status);
    try {
      const res  = await fetch(`${API}/git/trees/HEAD?recursive=1`);
      if (!res.ok) throw new Error(`GitHub API ${res.status}`);
      const data = await res.json();
      allPatches = data.tree
        .filter(f => f.type === 'blob' && f.path.endsWith('.ks'))
        .map(f => {
          const parts = f.path.split('/');
          return {
            path: f.path,
            name: parts[parts.length - 1],
            dir:  parts.length > 1 ? parts.slice(0, -1).join('/') : '',
          };
        })
        .sort((a, b) => a.path.localeCompare(b.path));
      loaded = true;
      if (allPatches.length === 0) {
        status.textContent = 'no .ks files found in repo';
      } else {
        render('');
      }
    } catch (e) {
      status.textContent = `error: ${e.message}`;
    }
  }

  function render(filter) {
    list.innerHTML = '';
    const q = filter.toLowerCase();
    const matches = allPatches.filter(p =>
      !q || p.path.toLowerCase().includes(q)
    );
    if (matches.length === 0) {
      const s = document.createElement('div');
      s.id = 'patch-status';
      s.textContent = 'no matches';
      list.appendChild(s);
      return;
    }
    let lastDir = null;
    matches.forEach(p => {
      if (p.dir !== lastDir) {
        const d = document.createElement('div');
        d.className = 'patch-dir';
        d.textContent = p.dir || '/';
        list.appendChild(d);
        lastDir = p.dir;
      }
      const btn = document.createElement('button');
      btn.className = 'patch-item';
      btn.textContent = p.name;
      btn.title = p.path;
      btn.addEventListener('click', () => loadPatch(p));
      list.appendChild(btn);
    });
  }

  async function loadPatch(p) {
    const btn = list.querySelector(`[title="${p.path}"]`);
    if (btn) { btn.textContent = '…'; btn.disabled = true; }
    try {
      const res = await fetch(`${RAW}/${p.path}`);
      if (!res.ok) throw new Error(`fetch ${res.status}`);
      const text = await res.text();
      editor.value = text;
      close();
      editor.focus();
    } catch (e) {
      if (btn) { btn.textContent = p.name; btn.disabled = false; }
      alert(`Could not load ${p.path}: ${e.message}`);
    }
  }

  btnFix.addEventListener('click', e => { reconnectAudio(); });
  btnOpen.addEventListener('click', open);
  btnClose.addEventListener('click', close);
  browser.addEventListener('click', e => { if (e.target === browser) close(); });
  search.addEventListener('input', () => { if (loaded) render(search.value); });
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && browser.classList.contains('open')) close();
  });
}());

/* ═══════════════════════════════════════════════════════════════════
   RESIZABLE SPLIT (desktop)
   ═══════════════════════════════════════════════════════════════════ */

(function () {
  const divider   = document.getElementById('divider');
  const main      = document.getElementById('main');
  let dragging    = false;
  let startX      = 0;
  let startW      = 0;

  const rightPanel = document.getElementById('right-panel');

  function setRightWidth(px) {
    const mainW   = main.offsetWidth;
    const minL    = 180;
    const minR    = 200;
    const clamped = Math.max(minR, Math.min(px, mainW - minL - 5));
    const pct     = (clamped / mainW * 100).toFixed(2) + '%';
    document.documentElement.style.setProperty('--right-w', pct);
  }

  divider.addEventListener('pointerdown', e => {
    if (window.innerWidth < 768) return;
    dragging = true;
    startX   = e.clientX;
    startW   = rightPanel.offsetWidth;
    divider.classList.add('dragging');
    divider.setPointerCapture(e.pointerId);
    e.preventDefault();
  });

  divider.addEventListener('pointermove', e => {
    if (!dragging) return;
    // moving left increases right panel width
    setRightWidth(startW - (e.clientX - startX));
  });

  divider.addEventListener('pointerup', () => {
    dragging = false;
    divider.classList.remove('dragging');
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth < 768) return;
    setRightWidth(rightPanel.offsetWidth);
  });
}());

/* ═══════════════════════════════════════════════════════════════════
   BOOT
   ═══════════════════════════════════════════════════════════════════ */

renderSlotStrip();
initWasm();
editor.focus();
</script>
</body>
</html>
```

